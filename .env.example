# ToolDNS Configuration
# Copy this to .env and fill in your values

# API key for authenticating requests to ToolDNS
# Generate one with: python -c "import secrets; print('td_' + secrets.token_hex(24))"
TOOLDNS_API_KEY=td_your_api_key_here

# Host and port for the ToolDNS server
TOOLDNS_HOST=0.0.0.0
TOOLDNS_PORT=8787

# Embedding model (default: all-MiniLM-L6-v2, ~23MB, runs on CPU)
TOOLDNS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Database path (default: ./tooldns.db)
TOOLDNS_DB_PATH=./tooldns.db

# Auto-refresh interval in minutes (0 = disabled)
TOOLDNS_REFRESH_INTERVAL=15

# Log level (DEBUG, INFO, WARNING, ERROR)
TOOLDNS_LOG_LEVEL=INFO
